[
  {
    "name": "Create user",
    "method": "POST",
    "path": "/api/users",
    "body": {
      "name": "User Flow",
      "email": "flow@ou.edu.vn",
      "password": "123456",
      "roleId": 1
    },
    "expect": 201
  },
  {
    "name": "Create book quantity = 2",
    "method": "POST",
    "path": "/api/books",
    "body": {
      "title": "Flow Book",
      "isbn": "ISBN-FLOW",
      "quantity": 2
    },
    "expect": 201
  },
  {
    "name": "Borrow book",
    "method": "POST",
    "path": "/api/borrow",
    "body": {
      "userId": 1,
      "bookId": 1
    },
    "expect": 201
  },
  {
    "name": "Get borrow list",
    "method": "GET",
    "path": "/api/borrow/user/1",
    "body": null,
    "expect": 200
  },
  {
    "name": "Renew book",
    "method": "PUT",
    "path": "/api/borrow/1/renew",
    "body": null,
    "expect": 200
  },
  {
    "name": "Return book",
    "method": "PUT",
    "path": "/api/borrow/return/1",
    "body": null,
    "expect": 200
  },
  {
    "name": "Verify after return",
    "method": "GET",
    "path": "/api/borrow/user/1",
    "body": null,
    "expect": 200
  }
]